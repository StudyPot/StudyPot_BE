STUDYPOT_IMAGE=ghcr.io/studypot/studypot-api:replace-with-commit-sha
STUDYPOT_HTTP_PORT=8080

STUDYPOT_MYSQL_DATABASE=studypot
STUDYPOT_MYSQL_JDBC_PARAMS=useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=utf8&connectionTimeZone=UTC
STUDYPOT_MYSQL_ROOT_PASSWORD=replace-with-generated-root-password
SPRING_DATASOURCE_USERNAME=studypot
SPRING_DATASOURCE_PASSWORD=replace-with-generated-app-password

STUDYPOT_REDIS_PASSWORD=replace-with-generated-redis-password
STUDYPOT_REDIS_MAXMEMORY=96mb

STUDYPOT_RABBITMQ_USERNAME=studypot
STUDYPOT_RABBITMQ_PASSWORD=replace-with-generated-rabbitmq-password
STUDYPOT_RABBITMQ_ERL_ARGS=+S 1:1 +sbwt none +sbwtdcpu none +sbwtdio none

STUDYPOT_AUTH_JWT_SECRET=replace-with-existing-or-generated-jwt-secret
STUDYPOT_AUTH_JWT_ISSUER=https://studypot.rumiclean.com
STUDYPOT_AUTH_OAUTH2_BACKEND_CALLBACK_URI=https://studypot.rumiclean.com/api/login/oauth2/code/google
STUDYPOT_AUTH_COOKIE_DOMAIN=studypot.rumiclean.com

# GitHub Actions writes these values to .runtime.env during normal deployments.
# Keep fallback values here only for manual compose runs.
STUDYPOT_AUTH_OAUTH2_FRONTEND_SUCCESS_URI=https://studypot.netlify.app/auth/success
STUDYPOT_AUTH_OAUTH2_FRONTEND_FAILURE_URI=https://studypot.netlify.app/auth/failure
STUDYPOT_CORS_ALLOWED_ORIGINS=https://studypot.netlify.app,https://studypot.rumiclean.com
STUDYPOT_AUTH_COOKIE_SAME_SITE=None
STUDYPOT_AUTH_COOKIE_SECURE=true
STUDYPOT_CORS_ALLOW_CREDENTIALS=true

STUDYPOT_GOOGLE_CLIENT_ID=
STUDYPOT_GOOGLE_CLIENT_SECRET=
STUDYPOT_GOOGLE_SCOPES=openid,email,profile

# LLM 사용 기록 관리자 페이지(/admin/llm-usage.html) 접근을 허용할 이메일. 쉼표로 구분.
STUDYPOT_ADMIN_EMAILS=

STUDYPOT_AI_OPENAI_API_KEY=
STUDYPOT_AI_OPENAI_BASE_URL=https://api.openai.com/v1
STUDYPOT_AI_OPENAI_MODEL=gpt-5-nano
STUDYPOT_AI_OPENAI_MODEL_DETAIL_KEYWORD_SUGGEST=
# 용도별 모델 오버라이드(비우면 위 기본 모델로 폴백)
STUDYPOT_AI_OPENAI_MODEL_CURRICULUM_GENERATE=gpt-5-mini
STUDYPOT_AI_OPENAI_MODEL_RETROSPECTIVE_FEEDBACK=
STUDYPOT_AI_OPENAI_MODEL_TEAM_LEAD_CHAT=
STUDYPOT_AI_OPENAI_API_MODE=responses
STUDYPOT_AI_OPENAI_CONNECT_TIMEOUT=5s
STUDYPOT_AI_OPENAI_READ_TIMEOUT=120s
STUDYPOT_AI_OPENAI_MAX_OUTPUT_TOKENS_DETAIL_KEYWORD_SUGGEST=256
STUDYPOT_AI_OPENAI_MAX_OUTPUT_TOKENS_CURRICULUM_GENERATE=16384
STUDYPOT_AI_OPENAI_MAX_OUTPUT_TOKENS_RETROSPECTIVE_FEEDBACK=2048
STUDYPOT_AI_OPENAI_MAX_OUTPUT_TOKENS_TEAM_LEAD_CHAT=1536
STUDYPOT_AI_OPENAI_REASONING_EFFORT_DETAIL_KEYWORD_SUGGEST=minimal

STUDYPOT_OPENAPI_ENABLED=false
STUDYPOT_SWAGGER_UI_ENABLED=false
STUDYPOT_OPENAPI_PUBLIC_DOCS_ENABLED=false
STUDYPOT_RATE_LIMIT_ENABLED=true
STUDYPOT_REDIS_HEALTH_ENABLED=true
STUDYPOT_NOTIFICATION_RABBITMQ_ENABLED=true
STUDYPOT_RABBITMQ_HEALTH_ENABLED=true
